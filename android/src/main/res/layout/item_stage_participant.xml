<?xml version="1.0" encoding="utf-8"?>
<!-- Preview is full-bleed; metadata is a slim strip so video uses almost the whole tile (not a "postage stamp"). -->
<dev.aws.ivs_realtime.ParticipantItem xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:minHeight="120dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/participant_preview_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/participant_metadata_strip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#B3000000"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingTop="4dp"
            android:paddingEnd="6dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/participant_participant_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/participant_publishing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/participant_subscribed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/participant_video_muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/participant_audio_muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/participant_audio_level"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp" />
        </LinearLayout>
    </FrameLayout>
</dev.aws.ivs_realtime.ParticipantItem>
